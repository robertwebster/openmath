    "id": "equ-one-ex-1",
    "title": "Solving an addition equation",
    "difficulty": 1,
    "problem": "Solve $x + 7 = 15$.",
    "steps": [
      {
        "step": 1,
        "instruction": "Identify the operation applied to $x$.",
        "working": "$x$ has 7 added to it."
      },
      {
        "step": 2,
        "instruction": "Apply the inverse operation to both sides.",
        "working": "The inverse of adding 7 is subtracting 7:\n$$x + 7 - 7 = 15 - 7$$"
      },
      {
        "step": 3,
        "instruction": "Simplify.",
        "working": "$$x = 8$$"
      }
    ],
    "answer": "$x = 8$"
  },
  {
    "id": "equ-one-ex-2",
    "title": "Solving a division equation with a negative",
    "difficulty": 2,
    "problem": "Solve $\\dfrac{x}{-3} = 4$.",
    "steps": [
      {
        "step": 1,
        "instruction": "Identify the operation applied to $x$.",
        "working": "$x$ is divided by $-3$."
      },
      {
        "step": 2,
        "instruction": "Apply the inverse operation to both sides.",
        "working": "The inverse of dividing by $-3$ is multiplying by $-3$:\n$$\\frac{x}{-3} \\times (-3) = 4 \\times (-3)$$"
      },
      {
        "step": 3,
        "instruction": "Simplify.",
        "working": "$$x = -12$$"
      },
      {
        "step": 4,
        "instruction": "Check by substituting back into the original equation.",
        "working": "$$\\frac{-12}{-3} = 4 \\checkmark$$"
      }
    ],
    "answer": "$x = -12$"
  },
  {
    "id": "equ-one-ex-3",
    "title": "Solving an equation with a fractional coefficient",
    "difficulty": 3,
    "problem": "Solve $\\dfrac{3}{5}x = 6$.",
    "steps": [
      {
        "step": 1,
        "instruction": "Identify the operation applied to $x$.",
        "working": "$x$ is multiplied by $\\dfrac{3}{5}$."
      },
      {
        "step": 2,
        "instruction": "Apply the inverse operation to both sides.",
        "working": "The inverse of multiplying by $\\dfrac{3}{5}$ is multiplying by $\\dfrac{5}{3}$:\n$$\\frac{3}{5}x \\times \\frac{5}{3} = 6 \\times \\frac{5}{3}$$"
      },
      {
        "step": 3,
        "instruction": "Simplify the left side.",
        "working": "$$x = 6 \\times \\frac{5}{3}$$"
      },
      {
        "step": 4,
        "instruction": "Simplify the right side.",
        "working": "$$x = \\frac{30}{3} = 10$$"
      }
    ],
    "answer": "$x = 10$"
  }
]
