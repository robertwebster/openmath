  {
    "id": "cvt-ex-3",
    "title": "Ordering mixed forms",
    "difficulty": 3,
    "problem": "Arrange $\\dfrac{3}{5}$, $0.55$, and $62\\%$ in order from smallest to largest.",
    "steps": [
      {
        "step": 1,
        "instruction": "Convert all values to decimals.",
        "working": "$$\\frac{3}{5} = 3 \\div 5 = 0.6$$\n$$62\\% = 62 \\div 100 = 0.62$$\n$$0.55 = 0.55$$"
      },
      {
        "step": 2,
        "instruction": "Compare the decimal values.",
        "working": "$$0.55 < 0.6 < 0.62$$"
      },
      {
        "step": 3,
        "instruction": "Write the original values in that order.",
        "working": "$0.55$, $\\dfrac{3}{5}$, $62\\%$"
      }
    ],
    "answer": "$0.55$, $\\dfrac{3}{5}$, $62\\%$"
