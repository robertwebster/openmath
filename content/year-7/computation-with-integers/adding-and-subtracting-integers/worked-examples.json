    "difficulty": 3,
    "problem": "Calculate $-5 + 3 - (-4)$.",
    "steps": [
      {
        "step": 1,
        "instruction": "Rewrite the expression by replacing $- (-4)$ with $+ 4$.",
        "working": "$$-5 + 3 - (-4) = -5 + 3 + 4$$"
      },
      {
        "step": 2,
        "instruction": "Work from left to right. First add $-5$ and $3$.",
        "working": "$$-5 + 3 = -2$$"
      },
      {
        "step": 3,
        "instruction": "Then add $4$ to the result.",
