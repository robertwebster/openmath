    "title": "Finding the total amount repaid",
    "difficulty": 3,
    "problem": "Sarah borrows $\\$5000$ at $3.5\\%$ per annum simple interest for $4$ years. What is the total amount she must repay?",
    "steps": [
      {
        "step": 1,
        "instruction": "Identify the values.",
        "working": "$P = 5000$, $r = 0.035$ (convert $3.5\\%$ to a decimal), $n = 4$"
      },
      {
        "step": 2,
        "instruction": "Calculate the interest using $I = Prn$.",
        "working": "$I = 5000 \\times 0.035 \\times 4 = \\$700$"
      },
      {
        "step": 3,
        "instruction": "Find the total amount using $A = P + I$.",
        "working": "$A = 5000 + 700 = \\$5700$"
      }
    ],
    "answer": "Sarah must repay a total of $\\$5700$."
  }
