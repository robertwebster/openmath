  {
    "id": "si-ex-02",
    "title": "Finding the principal",
    "difficulty": 2,
    "problem": "Simple interest of $\\$192$ is earned at $4\\%$ per annum over $4$ years. Find the principal.",
    "steps": [
      {
        "step": 1,
        "instruction": "Identify the known values.",
        "working": "$I = 192$, $r = 0.04$, $n = 4$, $P = ?$"
      },
      {
        "step": 2,
        "instruction": "Rearrange the formula $I = Prn$ to make $P$ the subject.",
        "working": "$P = \\dfrac{I}{rn}$"
      },
      {
        "step": 3,
        "instruction": "Substitute and calculate.",
        "working": "$P = \\dfrac{192}{0.04 \\times 4} = \\dfrac{192}{0.16} = \\$1200$"
      }
    ],
    "answer": "The principal was $\\$1200$."
  },
