    "id": "zero-and-negative-indices-example-1",
    "title": "Evaluating a zero index",
    "difficulty": 1,
    "problem": "Evaluate $(-8)^0$.",
    "steps": [
      {
        "step": 1,
        "instruction": "Recall the zero index rule.",
        "working": "For any non-zero value $a$: $a^0 = 1$"
