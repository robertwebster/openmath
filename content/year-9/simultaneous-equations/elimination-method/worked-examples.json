    "problem": "Solve the simultaneous equations:\n  3x + 2y = 12\n  2x − y = 1",
    "steps": [
      {
        "step": 1,
        "instruction": "Multiply the second equation by 2 so the y-coefficients match in size.",
        "working": "2 × (2x − y) = 2 × 1\n4x − 2y = 2"
      },
      {
        "step": 2,
        "instruction": "Add the modified second equation to the first equation to eliminate y.",
        "working": "(3x + 2y) + (4x − 2y) = 12 + 2\n7x = 14"
      },
      {
        "step": 3,
        "instruction": "Solve for x.",
        "working": "x = 2"
      },
      {
        "step": 4,
        "instruction": "Substitute x = 2 into the second original equation to find y.",
        "working": "2(2) − y = 1\n4 − y = 1\ny = 3"
      },
      {
        "step": 5,
        "instruction": "Check in both original equations.",
        "working": "Equation 1: 3(2) + 2(3) = 6 + 6 = 12 ✓\nEquation 2: 2(2) − 3 = 1 ✓"
      }
    ],
    "answer": "x = 2, y = 3"
  },
