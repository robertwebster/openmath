    "title": "Direct subtraction eliminates a variable",
    "difficulty": 1,
    "problem": "Solve the simultaneous equations:\n  3x + 2y = 11\n  x + 2y = 5",
    "steps": [
      {
        "step": 1,
        "instruction": "The y-coefficients are both 2. Subtract the second equation from the first to eliminate y.",
        "working": "(3x + 2y) − (x + 2y) = 11 − 5\n2x = 6"
      },
      {
        "step": 2,
        "instruction": "Solve for x.",
        "working": "x = 3"
      },
      {
        "step": 3,
        "instruction": "Substitute x = 3 into the simpler equation to find y.",
        "working": "3 + 2y = 5\n2y = 2\ny = 1"
      },
      {
        "step": 4,
        "instruction": "Check in both original equations.",
        "working": "Equation 1: 3(3) + 2(1) = 9 + 2 = 11 ✓\nEquation 2: 3 + 2(1) = 5 ✓"
      }
    ],
    "answer": "x = 3, y = 1"
  },
  {
