  {
    "id": "y8-are-aoc-we03",
    "title": "Finding the area of a semicircle",
    "difficulty": 3,
    "problem": "Find the area of a semicircle with diameter $12$ cm. Give your answer correct to 2 decimal places.",
    "steps": [
      {
        "step": 1,
        "instruction": "Find the radius from the diameter.",
        "working": "$r = 12 \\div 2 = 6$ cm"
      },
      {
        "step": 2,
        "instruction": "Find the area of the full circle.",
        "working": "$A_{\\text{circle}} = \\pi r^2 = \\pi \\times 6^2 = 36\\pi$"
      },
      {
        "step": 3,
        "instruction": "A semicircle is half a full circle.",
        "working": "$A = \\dfrac{36\\pi}{2} = 18\\pi$"
      },
      {
        "step": 4,
        "instruction": "Calculate to 2 decimal places.",
        "working": "$A \\approx 56.55$ cm²"
      }
    ],
    "answer": "$A \\approx 56.55$ cm²"
  }
