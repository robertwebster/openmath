    "problem": "Solve for $x$: $$\\frac{x}{4} = \\frac{x + 9}{7}$$",
    "steps": [
      {
        "step": 1,
        "instruction": "Find the LCM of the two denominators.",
        "working": "The LCM of 4 and 7 is 28."
      },
      {
        "step": 2,
        "instruction": "Multiply both sides by 28 to clear all fractions.",
        "working": "$$28 \\times \\frac{x}{4} = 28 \\times \\frac{x + 9}{7}$$"
      },
      {
        "step": 3,
        "instruction": "Simplify both sides.",
        "working": "$7x = 4(x + 9)$"
      },
      {
        "step": 4,
        "instruction": "Expand the right side.",
        "working": "$7x = 4x + 36$"
      },
      {
        "step": 5,
        "instruction": "Subtract $4x$ from both sides.",
        "working": "$3x = 36$"
      },
      {
        "step": 6,
        "instruction": "Divide both sides by 3.",
        "working": "$x = 12$"
      },
      {
        "step": 7,
        "instruction": "Check by substituting back.",
        "working": "$\\frac{12}{4} = 3$ and $\\frac{12 + 9}{7} = \\frac{21}{7} = 3$ ✓"
      }
    ],
    "answer": "$x = 12$"
  }
